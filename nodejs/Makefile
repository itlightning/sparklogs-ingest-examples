# Aggregator Makefile for Node.js examples. The existing OTel / Winston / Bunyan
# examples don't yet have build/test integration; runnable OTel-bridge examples
# (Pino, Winston via @opentelemetry/winston-transport, Bunyan via the OTel
# instrumentation) are coming. For now this is a stub so `make` from the repo
# root succeeds across all languages.
.PHONY: build mock-test test clean
build mock-test test clean:
	@echo "[nodejs] no runnable examples wired in yet — see https://sparklogs.com/docs/ingest/data-sources/languages/nodejs"
